# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Password for the BizHub web interface (set once; stored as bcrypt hash)
BIZHUB_PASSWORD=changeme123

# Directory where the SQLite database is stored inside the container
BIZHUB_DATA_DIR=/data

# App version shown in the settings page (set automatically by CI/CD on releases)
# BIZHUB_VERSION=v1.0.0
